dataMap {
    id: Int (id)
    position: Geometry(point)? (position)
}
query «SELECT "t0"."id", "t0"."position" FROM "public"."Location" AS "t0" ORDER
       BY ST_Distance(CAST("position" AS geography),
       CAST(ST_SetSRID(ST_MakePoint(0, 0), 4326) AS geography)) ASC, "t0"."id"
       DESC»
params []
