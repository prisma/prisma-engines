dataMap {
    id: Int (id)
    position: Geometry(point)? (position)
}
query «SELECT "t0"."id", "t0"."position" FROM "public"."Location" AS "t0" WHERE
       (NOT ST_DWithin("position"::geography, ST_SetSRID(ST_MakePoint(0, 0),
       4326)::geography, 10000))»
