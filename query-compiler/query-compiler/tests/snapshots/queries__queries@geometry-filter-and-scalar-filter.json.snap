dataMap {
    id: Int (id)
    position: Geometry(point)? (position)
}
query «SELECT "t0"."id", "t0"."position" FROM "public"."Location" AS "t0" WHERE
       (ST_DWithin("position"::geography, ST_SetSRID(ST_MakePoint(0, 0),
       4326)::geography, 50000) AND "t0"."id" > $1)»
params [const(BigInt(100))]
