dataMap {
    id: Int (id)
    position: Geometry(point)? (position)
}
query «SELECT "t0"."id", "t0"."position" FROM "public"."Location" AS "t0" WHERE
       ST_Within("position", ST_GeomFromText('POLYGON((0 0, 0 2, 2 2, 2 0, 0
       0))', 4326))»
