dataMap {
    id: Int (id)
    name: String? (name)
    position: Geometry(point)? (position)
}
query «SELECT "t0"."id", "t0"."name", "t0"."position" FROM "public"."Location"
       AS "t0" WHERE ST_Within("position", ST_GeomFromText('POLYGON((-1 -1, -1
       5, 5 5, 5 -1, -1 -1))', 4326)) ORDER BY "t0"."id" ASC LIMIT $1»
params [const(BigInt(10))]
