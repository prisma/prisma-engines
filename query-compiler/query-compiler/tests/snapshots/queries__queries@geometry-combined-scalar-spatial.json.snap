---
dataMap {
    id: Int (id)
    name: String? (name)
    position: Geometry(point)? (position)
}
query «SELECT "t0"."id", "t0"."name", "t0"."position" FROM "public"."Location"
       AS "t0" WHERE (ST_DWithin("position"::geography,
       ST_SetSRID(ST_MakePoint(0, 0), 4326)::geography, 10000) AND
       "t0"."name"::text LIKE $1)»
params [const(String("Paris%"))]
