{
  "modelName": "Location",
  "action": "findMany",
  "query": {
    "arguments": {
      "where": {
        "AND": [
          {
            "position": {
              "near": {
                "point": [0, 0],
                "maxDistance": 10000
              }
            }
          },
          {
            "name": {
              "startsWith": "Paris"
            }
          }
        ]
      }
    },
    "selection": {
      "id": true,
      "name": true,
      "position": true
    }
  }
}
